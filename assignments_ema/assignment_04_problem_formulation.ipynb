    "   \"source\": [\n",
    "    \"## Step 2 — Justice principles\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Task 2.1** — Run JUSTICE under BAU (no abatement) with three welfare functions and compare results.\\n\",\n",
    "    \"\\n\",\n",
    "    \"> **Key insight:** What changes\\n\",\n",
    "    \"> is how welfare losses are aggregated, which determines the shape of the objective landscape\\n\",\n",
    "    \"> the MOEA will search. The choice of welfare function therefore changes the Pareto front.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"df869634\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-05-19T07:18:45.297910600Z\",\n",
    "     \"start_time\": \"2026-05-19T07:18:45.269268300Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# ── Step 1: Define which welfare functions to compare ─────────────────────────\\n\",\n",
    "    \"# Add at least 3 welfare functions to this dictionary.\\n\",\n",
    "    \"# Key = a label you choose (used in the output table), Value = the WelfareFunction enum member.\\n\",\n",
    "    \"# Available options: WelfareFunction.UTILITARIAN, PRIORITARIAN, SUFFICIENTARIAN, EGALITARIAN\\n\",\n",
    "    \"# Tip: check justice/util/enumerations.py for the full list.\\n\",\n",
    "    \"\\n\",\n",
    "    \"welfare_functions = {\\n\",\n",
    "    \"    # \\\"Utilitarian\\\": WelfareFunction.UTILITARIAN,   ← example\\n\",\n",
    "    \"    # YOUR CODE HERE\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ── Step 2: Define the BAU (no-abatement) policy ──────────────────────────────\\n\",\n",
