    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"a01ans-c01\",\n",
    "   \"metadata\": {\n",
    "    \"execution\": {\n",
    "     \"iopub.execute_input\": \"2026-04-02T09:51:19.076566Z\",\n",
    "     \"iopub.status.busy\": \"2026-04-02T09:51:19.076509Z\",\n",
    "     \"iopub.status.idle\": \"2026-04-02T09:51:20.061120Z\",\n",
    "     \"shell.execute_reply\": \"2026-04-02T09:51:20.060710Z\"\n",
    "    },\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-05-18T14:53:31.233746400Z\",\n",
    "     \"start_time\": \"2026-05-18T14:53:26.369698900Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"def justice_model(rho=0.015, eta=1.45, delta=1.0, ecs_ensemble=1, ecr_plateau=0.0):\\n\",\n",
    "    \"    \\\"\\\"\\\"EMA Workbench function model — configurable abatement, Utilitarian welfare.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Parameters\\n\",\n",
    "    \"    ----------\\n\",\n",
    "    \"    ecr_plateau : float\\n\",\n",
    "    \"        Emission control rate applied uniformly across all regions and timesteps.\\n\",\n",
    "    \"        0.0 = no abatement; 0.4 = 40% abatement (moderate policy).\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    JUSTICE.hard_reset()\\n\",\n",
    "    \"    ensemble_idx = int(np.round(np.clip(ecs_ensemble, 1, 1001)))\\n\",\n",
    "    \"    model = JUSTICE(\\n\",\n",
    "    \"        start_year=2015, end_year=2300, timestep=1,\\n\",\n",
    "    \"        scenario=2, climate_ensembles=ensemble_idx, stochastic_run=False,\\n\",\n",
    "    \"        social_welfare_function=WelfareFunction.UTILITARIAN,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    model.economy.pure_rate_of_social_time_preference = float(rho)\\n\",\n",
    "    \"    model.economy.elasticity_of_marginal_utility_of_consumption = float(eta)\\n\",\n",
    "    \"    model.welfare_function.pure_rate_of_social_time_preference = float(rho)\\n\",\n",
    "    \"    model.welfare_function.elasticity_of_marginal_utility_of_consumption = float(eta)\\n\",\n",
    "    \"    model.damage_function.coefficient_a                  *= float(delta)\\n\",\n",
    "    \"    model.damage_function.coefficient_b                  *= float(delta)\\n\",\n",
    "    \"    model.damage_function.damage_gdp_ratio_with_gradient *= float(delta)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    ecr = np.full(model.emission_control_rate.shape[:2], float(ecr_plateau))\\n\",\n",
    "    \"    model.run(emission_control_rate=ecr, endogenous_savings_rate=True)\\n\",\n",
    "    \"    datasets = model.evaluate()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    welfare = float(np.abs(np.squeeze(datasets[\\\"welfare\\\"])))\\n\",\n",
    "    \"    yat     = float(np.squeeze(\\n\",\n",
    "    \"        years_above_temperature_threshold(datasets[\\\"global_temperature\\\"], 2.0)\\n\",\n",
    "    \"    ))\\n\",\n",
    "    \"    _, _, _, wl_dmg = model.welfare_function.calculate_welfare(\\n\",\n",
    "    \"        datasets[\\\"damage_cost_per_capita\\\"], welfare_loss=True)\\n\",\n",
    "    \"    _, _, _, wl_abt = model.welfare_function.calculate_welfare(\\n\",\n",
    "    \"        datasets[\\\"abatement_cost_per_capita\\\"], welfare_loss=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Global mean temperature trajectory (shape: n_timesteps)\\n\",\n",
    "    \"    temp = np.squeeze(datasets[\\\"global_temperature\\\"])\\n\",\n",
    "    \"    if temp.ndim == 2:\\n\",\n",
    "    \"        temp = temp.mean(axis=0)\\n\",\n",
    "    \"    temperature_trajectory = temp.astype(float)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return {\\n\",\n",
    "    \"        \\\"welfare\\\":                          welfare,\\n\",\n",
    "    \"        \\\"years_above_temperature_threshold\\\": yat,\\n\",\n",
    "    \"        \\\"welfare_loss_damage\\\":              float(np.abs(np.squeeze(wl_dmg))),\\n\",\n",
    "    \"        \\\"welfare_loss_abatement\\\":           float(np.abs(np.squeeze(wl_abt))),\\n\",\n",
    "    \"        \\\"temperature_trajectory\\\":           temperature_trajectory,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Smoke test\\n\",\n",
    "    \"test = justice_model()\\n\",\n",
    "    \"for k, v in test.items():\\n\",\n",
    "    \"    if isinstance(v, np.ndarray):\\n\",\n",
    "    \"        print(f\\\"  {k}: array shape {v.shape}, range [{v.min():.2f}, {v.max():.2f}]\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(f\\\"  {k}: {v:.4f}\\\")\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"  welfare: 103.7211\\n\",\n",
    "      \"  years_above_temperature_threshold: 259.0000\\n\",\n",
    "      \"  welfare_loss_damage: 3980.5410\\n\",\n",
    "      \"  welfare_loss_abatement: 74364.1321\\n\",\n",
    "      \"  temperature_trajectory: array shape (286,), range [1.20, 6.01]\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 3\n",
    "  },\n",
