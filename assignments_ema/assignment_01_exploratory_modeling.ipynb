    "   \"source\": [\n",
    "    \"import os, sys\\n\",\n",
    "    \"# ── Add JUSTICE-main to sys.path so justice internal imports resolve ───────────\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    _NOTEBOOK_DIR = os.path.dirname(os.path.abspath(__vsc_ipynb_file__))\\n\",\n",
    "    \"except NameError:\\n\",\n",
    "    \"    _NOTEBOOK_DIR = os.path.abspath('.')\\n\",\n",
    "    \"_justice_root = os.path.normpath(os.path.join(_NOTEBOOK_DIR, '../JUSTICE-main'))\\n\",\n",
    "    \"\\n\",\n",
    "    \"_PLOTS_DIR = os.path.join(_NOTEBOOK_DIR, \\\"plots\\\")\\n\",\n",
    "    \"os.makedirs(_PLOTS_DIR, exist_ok=True)\\n\",\n",
    "    \"if _justice_root not in sys.path:\\n\",\n",
    "    \"    sys.path.insert(0, _justice_root)\\n\",\n",
    "    \"os.chdir(_justice_root)\\n\",\n",
    "    \"\\n\",\n",
    "    \"import warnings; warnings.filterwarnings(\\\"ignore\\\")\\n\",\n",
    "    \"import logging\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"from IPython.display import display\\n\",\n",
    "    \"from ema_workbench import (\\n\",\n",
    "    \"    Model, RealParameter, ScalarOutcome, ArrayOutcome,\\n\",\n",
    "    \"    perform_experiments, ema_logging, Sample,\\n\",\n",
    "    \"    SequentialEvaluator, MultiprocessingEvaluator,\\n\",\n",
    "    \")\\n\",\n",
    "    \"from justice.model import JUSTICE\\n\",\n",
    "    \"from justice.util.enumerations import WelfareFunction\\n\",\n",
    "    \"from justice.objectives.objective_functions import years_above_temperature_threshold\\n\",\n",
    "    \"\\n\",\n",
    "    \"ema_logging.log_to_stderr(logging.WARNING)   # suppress per-run INFO noise\\n\",\n",
    "    \"\\n\",\n",
    "    \"OBJECTIVES   = [\\\"welfare\\\", \\\"years_above_temperature_threshold\\\",\\n\",\n",
    "    \"                \\\"welfare_loss_damage\\\", \\\"welfare_loss_abatement\\\"]\\n\",\n",
    "    \"PARAMS       = [\\\"rho\\\", \\\"eta\\\", \\\"delta\\\", \\\"ecs_ensemble\\\"]\\n\",\n",
    "    \"POLICY_NAMES = [\\\"no_abatement\\\", \\\"moderate_abatement\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Imports OK\\\")\\n\",\n",
    "    \"import matplotlib.path as _mpath\\n\",\n",
    "    \"def _patched_path_deepcopy(self, memo=None):\\n\",\n",
    "    \"    if memo is None: memo = {}\\n\",\n",
    "    \"    new_path = _mpath.Path.__new__(_mpath.Path)\\n\",\n",
    "    \"    memo[id(self)] = new_path\\n\",\n",
    "    \"    verts = self._vertices.copy()\\n\",\n",
    "    \"    codes = self._codes.copy() if self._codes is not None else None\\n\",\n",
    "    \"    new_path.__init__(verts, codes,\\n\",\n",
    "    \"                      _interpolation_steps=self._interpolation_steps, readonly=False)\\n\",\n",
    "    \"    return new_path\\n\",\n",
    "    \"_mpath.Path.__deepcopy__ = _patched_path_deepcopy\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Imports OK\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
